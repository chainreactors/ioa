                "detail": {
                    "type": "string"
                }
            }
        },
        "protocols.Message": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "content_schema": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "content_type": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "meta": {
                    "type": "object",
