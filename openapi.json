{
    "swagger": "2.0",
    "info": {
        "description": "IOA is a multi-agent communication protocol server. Nodes register themselves, create or join spaces, and exchange messages in real time via HTTP and Server-Sent Events.",
        "title": "IOA (Internet of Agent) API",
        "contact": {},
        "version": "1.0"
    },
    "host": "127.0.0.1:8765",
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "Return ok when the IOA server and store are ready",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "Server is ready",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "503": {
                        "description": "Server is not ready",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/messages": {
            "get": {
                "description": "Return messages across spaces with optional filters. Unlike space-scoped reads, this projection includes space_id.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "messages"
                ],
                "summary": "List messages",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Space ID filter",
                        "name": "space_id",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Message ID filter",
                        "name": "message_id",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Node-connected filter: sender or refs.nodes",
                        "name": "node_id",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Sender node ID filter",
                        "name": "sender",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Referenced message ID filter",
                        "name": "ref_message",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Referenced node ID filter",
                        "name": "ref_node",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Pagination cursor: return messages after this ID",
                        "name": "after",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Maximum number of messages to return",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of messages",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/protocols.Message"
                            }
                        }
                    },
                    "404": {
                        "description": "Filter target not found",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Invalid query parameters",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/nodes": {
            "get": {
                "description": "Return all registered nodes",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "nodes"
                ],
                "summary": "List nodes",
                "responses": {
                    "200": {
                        "description": "List of nodes",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/protocols.Node"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Register a new node with the IOA server",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "nodes"
                ],
                "summary": "Register node",
                "parameters": [
                    {
                        "description": "Node registration payload",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/protocols.NodeCreate"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created node",
                        "schema": {
                            "$ref": "#/definitions/protocols.Node"
                        }
                    },
                    "422": {
                        "description": "Invalid request body",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/nodes/{nodeID}": {
            "get": {
                "description": "Return a specific node by its ID",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "nodes"
                ],
                "summary": "Get node",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Node ID",
                        "name": "nodeID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Node details",
                        "schema": {
                            "$ref": "#/definitions/protocols.Node"
                        }
                    },
                    "404": {
                        "description": "Node not found",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/nodes/{nodeID}/inbox": {
            "get": {
                "description": "Return messages from all joined spaces that reference the specified node",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "nodes"
                ],
                "summary": "Get node inbox",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Node ID",
                        "name": "nodeID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Pagination cursor: return messages after this ID",
                        "name": "after",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Maximum number of messages to return",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of inbox messages (includes space_id)",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/protocols.Message"
                            }
                        }
                    },
                    "404": {
                        "description": "Node not found",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Invalid query parameters",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/nodes/{nodeID}/sse": {
            "get": {
                "description": "Open a Server-Sent Events stream for messages addressed to the specified node across all spaces",
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "events"
                ],
                "summary": "Subscribe to node events",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Node ID",
                        "name": "nodeID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "SSE stream of protocols.Message events"
                    },
                    "404": {
                        "description": "Node not found",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Streaming not supported",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/ready": {
            "get": {
                "description": "Return ok when the IOA server and store are ready",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "Server is ready",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "503": {
                        "description": "Server is not ready",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/spaces": {
            "get": {
                "description": "Return all spaces with their node counts and message counts",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "spaces"
                ],
                "summary": "List spaces",
                "responses": {
                    "200": {
                        "description": "List of spaces",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/protocols.SpaceInfo"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Create a new space or join an existing one. If x-node-id header is provided, the caller node joins the space.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "spaces"
                ],
                "summary": "Create space",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Caller node ID",
                        "name": "x-node-id",
                        "in": "header"
                    },
                    {
                        "description": "Space creation payload",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/protocols.SpaceCreate"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Space info",
                        "schema": {
                            "$ref": "#/definitions/protocols.SpaceInfo"
                        }
                    },
                    "422": {
                        "description": "Invalid request body",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/spaces/{spaceID}": {
            "get": {
                "description": "Return details of a specific space including its nodes and message count",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "spaces"
                ],
                "summary": "Get space",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Space ID",
                        "name": "spaceID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Space details",
                        "schema": {
                            "$ref": "#/definitions/protocols.SpaceInfo"
                        }
                    },
                    "404": {
                        "description": "Space not found",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/spaces/{spaceID}/messages": {
            "get": {
                "description": "Read messages from a space. Supports filtering by message context, pagination, and node-scoped reads.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "messages"
                ],
                "summary": "Read messages",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Space ID",
                        "name": "spaceID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Caller node ID (filters messages addressed to this node)",
                        "name": "x-node-id",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "Return the context (ancestors/descendants) of this message",
                        "name": "message_id",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Traversal direction: upstream (ancestors) or downstream (descendants)",
                        "name": "direction",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Pagination cursor: return messages after this ID",
                        "name": "after",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Maximum number of messages to return",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "If true, return all messages ignoring node filtering",
                        "name": "all",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "If true, switch to SSE streaming mode",
                        "name": "listen",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of messages",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/protocols.Message"
                            }
                        }
                    },
                    "404": {
                        "description": "Space not found",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Invalid query parameters",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Send a message to the specified space. The sender is identified by the x-node-id header.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "messages"
                ],
                "summary": "Send message",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Space ID",
                        "name": "spaceID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Caller node ID (sender)",
                        "name": "x-node-id",
                        "in": "header"
                    },
                    {
                        "description": "Message payload",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/protocols.SendMessage"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created message",
                        "schema": {
                            "$ref": "#/definitions/protocols.Message"
                        }
                    },
                    "404": {
                        "description": "Space not found",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Invalid request body",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/spaces/{spaceID}/messages/{messageID}/sse": {
            "get": {
                "description": "Open a Server-Sent Events stream filtered to messages related to the specified message",
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "events"
                ],
                "summary": "Subscribe to message events",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Space ID",
                        "name": "spaceID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Message ID to filter related events",
                        "name": "messageID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "SSE stream of related protocols.Message events"
                    },
                    "404": {
                        "description": "Space or message not found",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Streaming not supported",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/spaces/{spaceID}/sse": {
            "get": {
                "description": "Open a Server-Sent Events stream for all messages in the specified space",
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "events"
                ],
                "summary": "Subscribe to space events",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Space ID",
                        "name": "spaceID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "SSE stream of protocols.Message events"
                    },
                    "404": {
                        "description": "Space not found",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Streaming not supported",
                        "schema": {
                            "$ref": "#/definitions/protocols.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
